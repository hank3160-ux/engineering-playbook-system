# -------------------------------------------------------
# 環境變數範本 — 複製為 .env 並填入實際值
# 警告：.env 絕對不可 commit 進 repository
# -------------------------------------------------------

# 應用程式設定
APP_NAME=your-service-name
APP_VERSION=0.1.0
DEBUG=false

# 伺服器設定
HOST=0.0.0.0
PORT=8000

# 日誌等級：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 資料庫（選用）
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mydb
